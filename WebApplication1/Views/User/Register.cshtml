@{
    ViewData["Title"] = "Registrace";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <h2>Registrace</h2>
        <form method="post">
            <div class="mb-3">
                <label for="username" class="form-label">Uživatelské jméno</label>
                <input type="text" class="form-control" id="username" name="username" placeholder="Zvolte uživatelské jméno" required />
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Heslo</label>
                <input type="password" class="form-control" id="password" name="password" placeholder="Heslo musí mít alespoň 6 znaků" required />
            </div>
            <div class="mb-3">
                <label for="passwordCheck" class="form-label">Potvrzení hesla</label>
                <input type="password" class="form-control" id="passwordCheck" name="passwordCheck" placeholder="Zadejte heslo znovu" required />
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.Error))
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <button type="submit" class="btn btn-primary">Registrovat</button>
        </form>
        <p class="mt-3">Již máte účet? <a asp-controller="User" asp-action="Login">Přihlaste se zde</a></p>
    </div>
</div>


