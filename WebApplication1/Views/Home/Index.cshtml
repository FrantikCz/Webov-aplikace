@{
    ViewData["Title"] = "Home Page";
}
    <header class="site-header">
        <div class="container">
            <h1>Monster — energetické nápoje</h1>
            <p class="tagline">Stručný přehled příchutí, složení a tipy pro užívání.</p>
        </div>
    </header>

    <main class="container">

        <section class="intro">
            <h2>O produktech</h2>
            <p>Monster je známý energetický nápoj dostupný v mnoha příchutích a formátech. Níže najdete populární příchutě, základní informace o složení a doporučení pro užívání.</p>
        </section>

        <section class="flavors">
            <h2>Příchutě (ukázka)</h2>

            <div class="grid">

                <article class="card">
                    <img src="obr/white.webp" alt="Bílá plechovka Monster Ultra White" />
                    <h3>Ultra White</h3>
                    <p>Osvěžující příchuť s typickým kofeinovým kopem. Jedna z nejoblíbenějších.</p>
                </article>

                <article class="card">
                    <img src="obr/klasik.jpg" alt="Klasická zelená plechovka Monster" />
                    <h3>Klasik</h3>
                    <p>Originální a nejrozšířenější varianta. Tradiční Monster chuť.</p>
                </article>

                <article class="card">
                    <img src="obr/mango.avif" alt="Barevná plechovka Monster Mango Loco" />
                    <h3>Mango Loco</h3>
                    <p>Intenzivní mangová příchuť pro milovníky sladkých tropických chutí.</p>
                </article>

            </div>
        </section>

        <section class="nutrition">
            <h2>Složení a výživové informace (orientačně)</h2>
            <ul>
                <li>Kofein: 80–160 mg na plechovku (dle varianty)</li>
                <li>Cukr: některé varianty obsahují cukr, jiné jsou bez cukru</li>
                <li>Další látky: taurin, vitamíny skupiny B, aroma</li>
            </ul>

            <p class="warning">
                <strong>Upozornění:</strong>
                Nepřekračujte doporučený denní příjem kofeinu. Energetické nápoje nejsou vhodné pro děti, těhotné a kojící ženy nebo osoby citlivé na kofein.
            </p>
        </section>

    </main>

