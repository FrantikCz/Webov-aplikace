@model WebApplication1.Models.Note

@{
    ViewData["Title"] = "Úprava poznámky";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h1>Úprava poznámky</h1>
            <hr />

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form method="post" action='@Url.Action("Edit", "Note", new { id = Model.Id })'>
                <div class="form-group mb-3">
                    <label for="title" class="form-label">Nadpis *</label>
                    <input type="text" class="form-control" id="title" name="title" value="@Model.Title" placeholder="Zadejte nadpis poznámky" required />
                </div>

                <div class="form-group mb-3">
                    <label for="content" class="form-label">Obsah *</label>
                    <textarea class="form-control" id="content" name="content" rows="10" placeholder="Zadejte obsah poznámky" required>@Model.Content</textarea>
                </div>

                <small class="text-muted">
                    Vytvořeno: @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                    @if (Model.UpdatedAt != null)
                    {
                        <br />
                        <text>Poslední úprava: @Model.UpdatedAt?.ToString("dd.MM.yyyy HH:mm")</text>
                    }
                </small>

                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary">Uložit změny</button>
                    <a href='@Url.Action("Index", "Note")' class="btn btn-secondary">Zrušit</a>
                </div>
            </form>
        </div>
    </div>
</div>
